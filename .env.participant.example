# Configuración de un NODO PARTICIPANTE
# Copia este archivo antes de arrancar un participante:
#   cp .env.participant.example .env
#
# Este ejemplo corresponde al Participante 1 (puerto 3001) usando la base de datos
# que levanta docker-compose.yml en el puerto 5432.
#
# Para un segundo participante, copia este archivo, cambia PORT a 3002 y apunta
# DB_PORT / DB_NAME a otra instancia de PostgreSQL (ver docs/06-guia-de-inicio.md).

PORT=3001

DB_HOST=localhost
DB_PORT=5432
DB_USER=admin
DB_PASSWORD=password
DB_NAME=participant_db
