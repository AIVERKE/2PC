# Configuración del NODO COORDINADOR
# Copia este archivo antes de arrancar el coordinador:
#   cp .env.coordinator.example .env
#
# El coordinador orquesta el protocolo 2PC y llama a los participantes
# listados en PARTICIPANTS. No necesita base de datos propia para el protocolo,
# pero la app se conecta a PostgreSQL al iniciar; puedes usar la misma DB local.

PORT=3000

DB_HOST=localhost
DB_PORT=5432
DB_USER=admin
DB_PASSWORD=password
DB_NAME=participant_db

# URLs de los participantes (sin barra al final), separadas por coma
PARTICIPANTS=http://localhost:3001,http://localhost:3002
